{
    "layer": "top",
    "position": "top",
    "mode": "dock",
    "exclusive": "true",
    "passthrough": "false",
    "height": "20",
    "gtk-layer-shell": true,

    "modules-left":
    [
	"custom/toggle", "hyprland/workspaces"
    ],

    "modules-center":
    [
	"hyprland/window"
    ],

    "modules-right":
    [
	"custom/updates",
	"group/metrics",
	"network",
	"bluetooth",
	"battery",
	"backlight",
	"pulseaudio",
	"custom/other",
	"clock"
    ],

    "custom/toggle":
    {
        "tooltip": false,
        "format" : "ůį£á ",
	"on-click" : "~/.scripts/waybar/toggleBar.sh"
    },

    "clock":
    {
        "tooltip": false,
        "format": "{:%R %a}"
    },

    "group/metrics":
    {
	"tooltip": false,
	"orientation": "horizontal",
	"modules": ["cpu", "memory"]
    },

    "cpu":
    {
	"tooltip": false,
        "interval": 30,
        "format" : "Ôíľ {}%",
        "max-length": 10,
	"on-click":"kitty -e btop"
    },


    "memory":
    {
	"tooltip": false,
        "interval": 1,
        "format": "ÔáÄ {}%",
        "max-length": 30
    },

    "network":
    {
	"tooltip": false,
	"format-icons":
	[
		"ůį§ü",
		"ůį§Ę",
		"ůį§•",
		"ůį§®"
	],

	"format-wifi": "{icon}",
	"format-ethernet": "ÓĹĄ",
	"format-linked": "ůįĄ°",
	"format-disconnected": "Óęź",
        "on-click": "kitty -e nmtui",
        "on-click-right": "nm-connection-editor"
    },

    "bluetooth":
    {
	"tooltip": false,
	"format": "ůįāĮ",
	"format-disabled": "ůįā≤",
	"format-connected": "ůįāĪ {num_connections}",
	"on-click": "blueman-manager"
    },

    "hyprland/window":
    {
	"tooltip": false,
        "format": "{initialTitle}"
    },

    "hyprland/workspaces":
    {
	"tooltip": false
    },

    "custom/updates":
    {
	"tooltip": false,
        "format": "{} Ôíá",
        "exec": "checkupdates | wc -l",
        "exec-if": "[[ $(checkupdates | wc -l) != 0 ]]",
        "interval": 200,
        "on-click": "kitty -e sudo pacman -Syyu"
    },

    "backlight":
    {
	"tooltip": false,
	"device": "intel_backlight",
	"format": "{icon}",
	"format-icons":
	[
		"ůįõ©",
		"ůĪ©é",
		"ůĪ©Ź",
		"ůĪ©ź",
		"ůĪ©Ď",
		"ůĪ©í",
		"ůĪ©ď",
		"ůĪ©Ē",
		"ůĪ©ē",
		"ůĪ©Ė",
		"ůįõ®"
	],
	"on-click": "brightnessctl set 50%",
	"on-scroll-up": "brightnessctl set 10%+",
	"on-scroll-down": "brightnessctl set 10%-"
    },

    "battery":
    {
	"tooltip": false,
	"full-at": 95,
	"states": {
		"warning": 35,
		"critical": 10
	},
	"format": "{icon}",
	"format-plugged": "Ôá¶",
	"format-charging": "ůįāĄ",
	"format-icons":
	[
		"ůįāé",
		"ůįĀļ",
		"ůįĀĽ",
		"ůįĀľ",
		"ůįĀĹ",
		"ůįĀĺ",
		"ůįĀŅ",
		"ůįāÄ",
		"ůįāĀ",
		"ůįāā",
		"ůįĀĻ"
	],
	"on-click": "kitty -e watch -n 2 upower -i /org/freedesktop/UPower/devices/battery_BAT0"
    },

    "pulseaudio":
    {
	"tooltip": false,
	"format": "{icon}",
	"format-muted": "ÓĽ®",
	"on-click": "wpctl set-mute @DEFAULT_SINK@ toggle",
	"on-click-right": "pavucontrol",
	"on-scroll-up": "wpctl set-volume -l 1.3 @DEFAULT_SINK@ 5%+",
	"on-scroll-down": "wpctl set-volume @DEFAULT_SINK@ 5%-",
	"scroll-step": 5,
	"format-icons": {
		"headphone": "ÔÄ•",
		"hands-free": "ÔÄ•",
		"headset": "ÔÄ•",
		"default": [
			"ÔÄ¶",
			"ÔÄß",
			"ÔÄ®"
		]
	}
    },

    "custom/other":
    {
        "tooltip": false,
        "exec": "pgrep hypridle >/dev/null && echo 'ůįĺę' || echo 'ůįõä'",
        "interval": 1,
        "on-click": "sh -c 'pidof hypridle >/dev/null && killall hypridle || hypridle &'"
    }
}
